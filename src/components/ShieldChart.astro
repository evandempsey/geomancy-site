---
/**
 * Structural diagram of the shield chart: Mothers and Daughters across the
 * top, Nieces below, then Witnesses and Judge. Cells are numbered
 * right-to-left, as the figures are traditionally set down.
 *
 * Given four `mothers` (figure ids or dots arrays), the whole shield is
 * computed with deriveChart and drawn with the actual figures — so a
 * worked example only ever states its Mothers and the arithmetic is
 * always right.
 */
import { deriveChart, chartFigures, type FigureDots } from '../lib/casting';
import { resolveDots, nameOf } from '../lib/figureData';
import { glyphGeometry } from '../lib/glyph';

interface Props {
  /** four Mothers, e.g. ['puer', 'amissio', 'albus', 'populus'] or dots arrays */
  mothers?: (string | number[])[];
  /** fifteen figures in chart order: I-IV, V-VIII, IX-XII, XIII-XIV, XV */
  figures?: (string | number[])[];
  caption?: string;
}

const { mothers: mothersProp, figures: figuresProp, caption } = Astro.props;

const W = 640;

let filled: { dots: FigureDots; name: string }[] | undefined;
let explicitChart = false;
if (mothersProp && figuresProp) {
  throw new Error('ShieldChart accepts either `mothers` or `figures`, not both');
}
if (figuresProp) {
  if (figuresProp.length !== 15) {
    throw new Error(`ShieldChart needs exactly fifteen figures, got ${figuresProp.length}`);
  }
  explicitChart = true;
  const resolved = await Promise.all(figuresProp.map(resolveDots));
  filled = await Promise.all(resolved.map(async (dots) => ({ dots, name: await nameOf(dots) })));
} else if (mothersProp) {
  if (mothersProp.length !== 4) {
    throw new Error(`ShieldChart needs exactly four Mothers, got ${mothersProp.length}`);
  }
  const mothers = await Promise.all(mothersProp.map(resolveDots));
  const ordered = chartFigures(deriveChart(mothers));
  filled = await Promise.all(ordered.map(async (dots) => ({ dots, name: await nameOf(dots) })));
}

// --- filled-chart geometry ---
const FROW = 150;
const FH = FROW * 4;
const fcellW = W / 8;
interface FilledCell {
  x: number;
  y: number;
  w: number;
  h: number;
  numeral: string;
  role: string;
  idx: number; // index into chartFigures order (Mothers I–IV = 0–3 … Judge = 14)
}
const filledCells: FilledCell[] = [
  ...['VIII', 'VII', 'VI', 'V', 'IV', 'III', 'II', 'I'].map((numeral, i) => ({
    x: i * fcellW,
    y: 0,
    w: fcellW,
    h: FROW,
    numeral,
    role: [
      '4th Daughter',
      '3rd Daughter',
      '2nd Daughter',
      '1st Daughter',
      '4th Mother',
      '3rd Mother',
      '2nd Mother',
      '1st Mother',
    ][i],
    idx: 7 - i,
  })),
  ...['XII', 'XI', 'X', 'IX'].map((numeral, i) => ({
    x: i * fcellW * 2,
    y: FROW,
    w: fcellW * 2,
    h: FROW,
    numeral,
    role: ['4th Niece', '3rd Niece', '2nd Niece', '1st Niece'][i],
    idx: 11 - i,
  })),
  { x: 0, y: FROW * 2, w: W / 2, h: FROW, numeral: 'XIV', role: 'Left Witness', idx: 13 },
  { x: W / 2, y: FROW * 2, w: W / 2, h: FROW, numeral: 'XIII', role: 'Right Witness', idx: 12 },
  { x: W / 4, y: FROW * 3, w: W / 2, h: FROW, numeral: 'XV', role: 'Judge', idx: 14 },
];
const GLYPH_SCALE = 0.72; // 72×96 glyph → ~52×69

const filledCaption =
  caption ??
  (filled
    ? explicitChart
      ? `A printed shield chart; the Judge is ${filled[14].name}.`
      : `A shield chart cast from the Mothers ${filled
          .slice(0, 4)
          .map((f) => f.name)
          .join(', ')}; the Judge is ${filled[14].name}.`
    : undefined);
const filledAria = filled
  ? explicitChart
    ? `Printed shield chart. Witnesses ${filled[12].name} and ${filled[13].name}; Judge ${filled[14].name}.`
    : `Shield chart cast from the Mothers ${filled
        .slice(0, 4)
        .map((f) => f.name)
        .join(', ')}. Witnesses ${filled[12].name} and ${filled[13].name}; Judge ${filled[14].name}.`
  : undefined;

// --- structural (no-prop) geometry, unchanged ---
const ROW1 = 80;
const ROW2 = 80;
const ROW3 = 90;
const H = ROW1 + ROW2 + ROW3 + 90;

const cellW = W / 8;
const row1 = [
  { n: 'VIII', label: '4th Daughter' },
  { n: 'VII', label: '3rd Daughter' },
  { n: 'VI', label: '2nd Daughter' },
  { n: 'V', label: '1st Daughter' },
  { n: 'IV', label: '4th Mother' },
  { n: 'III', label: '3rd Mother' },
  { n: 'II', label: '2nd Mother' },
  { n: 'I', label: '1st Mother' },
];
const row2 = [
  { n: 'XII', label: '4th Niece' },
  { n: 'XI', label: '3rd Niece' },
  { n: 'X', label: '2nd Niece' },
  { n: 'IX', label: '1st Niece' },
];
const row3 = [
  { n: 'XIV', label: 'Left Witness' },
  { n: 'XIII', label: 'Right Witness' },
];
---

{
  filled ? (
    <figure class="shield">
      <svg viewBox={`0 0 ${W} ${FH}`} role="img" aria-label={filledAria}>
        {filledCells.map((c) => {
          const fig = filled[c.idx];
          const geo = glyphGeometry(fig.dots);
          const gx = c.x + c.w / 2 - 36 * GLYPH_SCALE;
          return (
            <>
              <rect x={c.x} y={c.y} width={c.w} height={c.h} />
              <text class="numeral-sm" x={c.x + c.w / 2} y={c.y + 20}>
                {c.numeral}
              </text>
              <g transform={`translate(${gx}, ${c.y + 30}) scale(${GLYPH_SCALE})`}>
                {geo.circles.map((p) => (
                  <circle cx={p.cx} cy={p.cy} r={p.r} />
                ))}
              </g>
              <text class="figure-name" x={c.x + c.w / 2} y={c.y + 118}>
                {fig.name}
              </text>
              <text class="label" x={c.x + c.w / 2} y={c.y + 136}>
                {c.role}
              </text>
            </>
          );
        })}
      </svg>
      <figcaption>{filledCaption}</figcaption>
    </figure>
  ) : (
    <figure class="shield">
      <svg
        viewBox={`0 0 ${W} ${H}`}
        role="img"
        aria-label="Diagram of the geomantic shield chart: eight cells for the four Mothers and four Daughters, four cells for the Nieces, two for the Witnesses, and one for the Judge."
      >
        {row1.map((c, i) => (
          <>
            <rect x={i * cellW} y={0} width={cellW} height={ROW1} />
            <text class="numeral" x={i * cellW + cellW / 2} y={ROW1 / 2 - 4}>
              {c.n}
            </text>
            <text class="label" x={i * cellW + cellW / 2} y={ROW1 / 2 + 18}>
              {c.label}
            </text>
          </>
        ))}
        {row2.map((c, i) => (
          <>
            <rect x={i * cellW * 2} y={ROW1} width={cellW * 2} height={ROW2} />
            <text class="numeral" x={i * cellW * 2 + cellW} y={ROW1 + ROW2 / 2 - 4}>
              {c.n}
            </text>
            <text class="label" x={i * cellW * 2 + cellW} y={ROW1 + ROW2 / 2 + 18}>
              {c.label}
            </text>
          </>
        ))}
        {row3.map((c, i) => (
          <>
            <rect x={i * cellW * 4} y={ROW1 + ROW2} width={cellW * 4} height={ROW3} />
            <text class="numeral" x={i * cellW * 4 + cellW * 2} y={ROW1 + ROW2 + ROW3 / 2 - 4}>
              {c.n}
            </text>
            <text class="label" x={i * cellW * 4 + cellW * 2} y={ROW1 + ROW2 + ROW3 / 2 + 18}>
              {c.label}
            </text>
          </>
        ))}
        <rect x={W / 4} y={ROW1 + ROW2 + ROW3} width={W / 2} height={86} />
        <text class="numeral" x={W / 2} y={ROW1 + ROW2 + ROW3 + 38}>
          XV
        </text>
        <text class="label" x={W / 2} y={ROW1 + ROW2 + ROW3 + 60}>
          Judge
        </text>
      </svg>
      <figcaption>
        {
          caption ?? (
            <>
              The shield chart. The figures are set down from right to left: the four Mothers
              (I–IV), the four Daughters (V–VIII), the four Nieces (IX–XII), the two Witnesses
              (XIII–XIV) and the Judge (XV).
            </>
          )
        }
      </figcaption>
    </figure>
  )
}

<style>
  .shield {
    margin: var(--space-8) 0;
  }
  svg {
    width: 100%;
    height: auto;
  }
  rect {
    fill: var(--color-bg-raised);
    stroke: var(--color-border-strong);
    stroke-width: 1.5;
  }
  circle {
    fill: var(--color-ink);
  }
  text {
    text-anchor: middle;
    fill: var(--color-ink);
  }
  .numeral {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
  }
  .numeral-sm {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 600;
    fill: var(--color-ink-muted);
  }
  .figure-name {
    font-family: var(--font-serif);
    font-size: 13px;
    font-style: italic;
  }
  .label {
    font-family: var(--font-ui);
    font-size: 12px;
    fill: var(--color-ink-muted);
  }
  figcaption {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-top: var(--space-2);
  }
</style>
