---
import { getEntry } from 'astro:content';
import { chapterSlug } from '../../lib/library';

/**
 * The required-reading panel of a lesson. Items are either library
 * chapter references (resolved to title + source + URL) or internal
 * hrefs with explicit labels.
 */
interface ReadingItem {
  chapter?: { collection: 'library'; id: string };
  href?: string;
  label?: string;
  note?: string;
}

interface Props {
  items: ReadingItem[];
  title?: string;
}

const { items, title = 'Required reading' } = Astro.props;

const resolved = await Promise.all(
  items.map(async (item) => {
    if (item.chapter) {
      const chapter = await getEntry('library', item.chapter.id);
      if (!chapter) throw new Error(`Reading chapter not found: ${item.chapter.id}`);
      const source = await getEntry('sources', chapter.data.source.id);
      if (!source) throw new Error(`Source not found for chapter ${chapter.id}`);
      return {
        href: `/library/${source.id}/${chapterSlug(chapter)}/`,
        label: chapter.data.title,
        detail: `${source.data.author}, ${source.data.shortTitle}`,
        note: item.note,
      };
    }
    if (!item.href || !item.label) throw new Error('Reading needs a chapter or href+label');
    return { href: item.href, label: item.label, detail: undefined, note: item.note };
  }),
);
---

<aside class="reading" aria-label={title}>
  <p class="reading-kicker">{title}</p>
  <ul>
    {
      resolved.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
          {item.detail && <span class="detail">, {item.detail}</span>}
          {item.note && <span class="note"> ({item.note})</span>}
        </li>
      ))
    }
  </ul>
  <slot />
</aside>

<style>
  .reading {
    background: var(--color-bg-inset);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-8) 0;
  }
  .reading-kicker {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin: 0 0 var(--space-2);
  }
  ul {
    margin: 0;
    padding-left: var(--space-6);
  }
  li {
    margin: var(--space-1) 0;
  }
  .detail,
  .note {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
</style>
