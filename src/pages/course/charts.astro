---
import Prose from '../../layouts/Prose.astro';
import ShieldChart from '../../components/ShieldChart.astro';
import HouseChart from '../../components/HouseChart.astro';
import GerardChart from '../../components/GerardChart.astro';

const charts = [
  {
    label: 'A',
    question: 'Will the marriage go ahead?',
    mothers: ['conjunctio', 'via', 'amissio', 'caput-draconis'],
    mothersNames: 'Conjunctio, Via, Amissio, Caput Draconis',
    note: 'This chart has heavy repetition: Conjunctio stands in houses 1 and 5, Via in 2 and 7, Amissio in 3 and 12, and Puer in 6 and 10. The Witnesses are Rubeus and Tristitia, two harsh figures. The Judge is Acquisitio, gain. The seventh house, the house of the question, holds Via, the most changeable figure of the sixteen.',
  },
  {
    label: 'B',
    question: 'Will the querent recover the partnership?',
    mothers: ['puella', 'rubeus', 'rubeus', 'amissio'],
    mothersNames: 'Puella, Rubeus, Rubeus, Amissio',
    note: 'This chart starts with Rubeus twice among the Mothers. That produces Carcer twice among the Daughters and Via twice among the Nieces. The Judge is Via, a figure of change, produced from Tristitia and Cauda Draconis. Lesson 10 reads this as a denial of restoration.',
  },
  {
    label: 'C',
    question: 'Will the querent win the lawsuit?',
    mothers: ['amissio', 'amissio', 'puella', 'fortuna-minor'],
    mothersNames: 'Amissio, Amissio, Puella, Fortuna Minor',
    note: 'Chart C is the conflict chart. The Judge is Acquisitio, a favorable figure. The seventh house, the house of this question, holds Cauda Draconis, an unfavorable figure. Lesson 10 uses it to show how to place divided findings in their roles.',
  },
  {
    label: 'D',
    question: 'Will the querent get the office they seek?',
    mothers: ['acquisitio', 'fortuna-major', 'via', 'amissio'],
    mothersNames: 'Acquisitio, Fortuna Major, Via, Amissio',
    note: 'Chart D is read from scratch in Lesson 10. It perfects by occupation: Acquisitio stands in both the first house and the tenth, the house of the office sought. The Judge is Fortuna Major. The fourth house holds Amissio, and the Part of Fortune falls in the eighth. The answer is yes, with cost.',
  },
  {
    label: 'J',
    question: 'Will the querent get what they hope for?',
    mothers: ['fortuna-major', 'via', 'amissio', 'albus'],
    mothersNames: 'Fortuna Major, Via, Amissio, Albus',
    note: 'Final Practice reading I, in Lesson 13. This is an eleventh-house hope question. The chart perfects when the querent’s Fortuna Major appears in the twelfth, beside the eleventh house. The Part of Fortune also falls in the twelfth, on the querent’s figure. The eleventh holds Albus, repeated in the fourth. The Witnesses are Rubeus and Tristitia, and the Judge is Acquisitio.',
  },
  {
    label: 'K',
    question: 'Will the prisoner be released?',
    mothers: ['tristitia', 'puer', 'puer', 'rubeus'],
    mothersNames: 'Tristitia, Puer, Puer, Rubeus',
    note: 'Final Practice reading II, in Lesson 13. The prison’s house holds Cauda Draconis, the Judge is Amissio, the officials’ house holds Carcer, and the Part of Fortune falls in the twelfth. The chart still perfects by the querent’s approach: Tristitia stands in the eleventh, beside the prison. The Witness-Judge table also gives release for a prison question. The answer is release, but difficult and slow.',
  },
  {
    label: 'L',
    question: 'Will the intended marriage go ahead?',
    mothers: ['acquisitio', 'albus', 'carcer', 'via'],
    mothersNames: 'Acquisitio, Albus, Carcer, Via',
    note: 'The course’s last marriage chart asks the same kind of question as Chart A. It perfects by occupation: Acquisitio stands in both the first house and the seventh. The triad is Chart A’s triad reversed, with Tristitia and Rubeus producing Acquisitio. The Part of Fortune falls in the eighth on Puella. Lesson 13 reads it beside its Gerard companion, Chart M.',
  },
];

/**
 * The Gerard charts of Lesson 12 — celestial charts of astronomical
 * geomancy, not shields. Planet placements are the frozen facts of
   * the Gerard chart reference file, asserted by the Gerard chart check script.
 * Charts H and I are exercise charts and stay inside the lesson.
 */
const gerardCharts = [
  {
    label: 'E',
    question: 'Will the querent live a long life?',
    ascendant: 'fortuna-major',
    ascendantName: 'Fortuna Major',
    planets: {
      Sun: 7, Moon: 3, Venus: 5, Mercury: 2, Saturn: 10,
      Jupiter: 1, Mars: 9, 'Caput Draconis': 4, 'Cauda Draconis': 6,
    },
    note: 'Fortuna Major cast for the Ascendant puts Aquarius (not the Leo of the course’s default attributions) on the first house, and Saturn, its lord, stands in the tenth, a strong angle: long life, by the greater years of Saturn. Jupiter keeps the first house, the Sun stays out of the eighth, and every mortal configuration of Gerard’s first-house chapter answers in the negative.',
  },
  {
    label: 'F',
    question: 'Whether the sick man will recover his health, or die?',
    ascendant: 'carcer',
    ascendantName: 'Carcer',
    planets: {
      Sun: 8, Moon: 11, Venus: 1, Mercury: 6, Saturn: 1,
      Jupiter: 5, Mars: 5, 'Caput Draconis': 3, 'Cauda Draconis': 10,
    },
    note: 'Chart F is the course’s main sickness chart in Gerard’s system. Saturn sits in the first house with Venus, the lady of the eighth, while the Sun occupies the eighth itself. Jupiter, lord of the Ascendant, is joined with Mars in the fifth, and the Dragon’s Tail holds the midheaven. Lesson 12 reads Gerard’s sickness rules through it part by part.',
  },
  {
    label: 'G',
    question: 'Will the physician cure the sick man with his medicines?',
    ascendant: 'puella',
    ascendantName: 'Puella',
    planets: {
      Sun: 4, Moon: 7, Venus: 12, Mercury: 9, Saturn: 10,
      Jupiter: 1, Mars: 7, 'Caput Draconis': 8, 'Cauda Draconis': 2,
    },
    note: 'For this question Gerard gives the first house to the physician, the tenth to the sick man, the seventh to his diseases, and the fourth to the medicines. Jupiter in the first promises the physician will profit. Saturn in the tenth says the sick man is a cause of his own disease. Mars and the Moon occupy the seventh. Venus reaches the twelfth by exactly thirty-six points: the remainder of nought that counts as twelve.',
  },
  {
    label: 'M',
    question: 'Will the intended marriage go ahead?',
    ascendant: 'conjunctio',
    ascendantName: 'Conjunctio',
    planets: {
      Sun: 4, Moon: 7, Venus: 11, Mercury: 10, Saturn: 3,
      Jupiter: 1, Mars: 8, 'Caput Draconis': 7, 'Cauda Draconis': 6,
    },
    note: 'This is Chart L’s marriage question, cast independently in Gerard’s system for Lesson 13. Conjunctio puts Virgo on the Ascendant. Jupiter, lord of the seventh, stands in the first, and the Moon stands in the seventh. The Dragon’s Head is also in the seventh, Mercury holds the midheaven, and no infortune touches the first or seventh. Gerard’s marriage rule gives yes; the comparison note beside Chart L is agree.',
  },
];
---

<Prose
  title="The Course Charts"
  description="The fixed example charts of the Geomancy Course: shields A–D and J–L, and the celestial charts E–G and M of Gerard's astronomical geomancy, with their questions."
  crumbs={[{ name: 'The Course', href: '/course/' }, { name: 'The Course Charts' }]}
  kicker="The Geomancy Course"
>
  <p>
    Seven shield charts accompany the course as fixed worked examples:
    Charts A, B and C from Lesson 4; Chart D from Lesson 10, where it is read from scratch as
    a model written reading; and Charts J, K and L, the final-practice charts of Lesson 13,
    published here because its staged model solutions read them whole. Each is a complete cast
    with a standing question; every reading lesson returns to them with its new tool.
    They are reproduced here in full so that any lesson, and any reading of your own, can refer
    back to one standard copy. Each shield below is computed by the site's casting tool from
    the four Mothers; if you derive them by hand, as Lesson 4 asks, your results must agree
    exactly.
  </p>

  {
    charts.map((c) => (
      <section>
        <h2>Chart {c.label}: “{c.question}”</h2>
        <p>
          <strong>Mothers:</strong> {c.mothersNames}.
        </p>
        <ShieldChart mothers={c.mothers} caption={`Chart ${c.label}: the complete shield.`} />
        <HouseChart mothers={c.mothers} caption={`Chart ${c.label} set into the twelve houses.`} />
        <p>{c.note}</p>
      </section>
    ))
  }

  <section>
    <h2>The Gerard charts</h2>
    <p>
      Lesson 12 adds charts of a different kind: celestial charts of Gerard of Cremona's
      astronomical geomancy, in which a single cast figure puts a sign on the Ascendant, the signs
      follow in zodiacal order, and nine projections of points place the planets. There is no
      shield here, no Witnesses and no Judge: these charts are read by lords, planets and signs.
      The two exercise charts of that lesson, H and I, are not reproduced here: erecting them is
      the exercise. Chart M, the final-practice celestial half of Lesson 13's marriage question,
      closes the set.
    </p>
  </section>

  {
    gerardCharts.map((c) => (
      <section>
        <h2>Chart {c.label}: “{c.question}”</h2>
        <p>
          <strong>Ascendant figure:</strong> {c.ascendantName}.
        </p>
        <GerardChart
          ascendant={c.ascendant}
          planets={c.planets}
          caption={`Chart ${c.label}: the erected celestial figure.`}
        />
        <p>{c.note}</p>
      </section>
    ))
  }

</Prose>
