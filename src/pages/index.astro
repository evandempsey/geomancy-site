---
import { withBase } from '../lib/url';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FigureGlyph from '../components/FigureGlyph.astro';

const figures = (await getCollection('figures')).sort((a, b) => a.data.order - b.data.order);
const sources = (await getCollection('sources')).sort((a, b) => a.data.order - b.data.order);

const jsonLd = [
  {
    '@type': 'WebSite',
    name: 'The Art of Geomancy',
    url: new URL(withBase('/'), Astro.site).href,
    description:
      'The figures, houses and readings of traditional geomancy, quoted from the historical sources: pseudo-Abano, Cattan, Heydon, Agrippa, Gerard of Cremona and Crowley.',
  },
];
---

<Base
  title="The Art of Geomancy: the historical sources of geomantic divination"
  description="A reference library of medieval and Renaissance geomancy: the sixteen figures, the twelve houses and the reading techniques, quoted directly from pseudo-Abano, Cattan, Heydon, Agrippa and the other historical sources."
  type="website"
  jsonLd={jsonLd}
  wide
>
  <section class="hero">
    <h1>Geomancy, from the historical sources</h1>
    <p>
      Geomancy was the great divinatory art of medieval and Renaissance Europe, “the daughter of
      Astrologie”, read through sixteen figures of points cast into the twelve houses of heaven. This
      site presents the art as its historical authors taught it: every interpretation on these pages is
      quoted directly, with citation, from the public-domain sources: the pseudo-Abano
      <em>Method of Judging Questions</em>, Christopher Cattan’s <em>Geomancie</em> (1591), John
      Heydon’s <em>Theomagia</em> (1663), the <em>Of Geomancy</em> attributed to Cornelius Agrippa
      and the <em>Astronomical Geomancy</em> of Gerard of Cremona (1655), and Aleister Crowley’s
      Equinox handbook (1909).
    </p>
    <nav class="start" aria-label="Start here">
      <a href={withBase('/what-is-geomancy/')}>What is geomancy?</a>
      <a href={withBase('/casting/')}>How to cast a chart</a>
      <a href={withBase('/library/')}>Read the texts</a>
      <a href={withBase('/tools/')}>Practice tools</a>
    </nav>
  </section>

  <section class="course-card">
    <h2>The Geomancy Course</h2>
    <p>
      A complete education in the art, free, in thirteen lessons: from the worldview of the
      Renaissance geomancers through the sixteen figures, casting, the houses and the reading
      techniques, to Gerard of Cremona’s astrological geomancy. Every lesson teaches from the
      primary sources, with worked examples, practice tools and exercises you grade yourself
      against full model answers.
    </p>
    <p><a href={withBase('/course/')}>Begin the course →</a></p>
  </section>

  <section>
    <h2>The sixteen figures</h2>
    <ul class="figure-grid">
      {
        figures.map((f) => (
          <li>
            <a href={withBase(`/figures/${f.id}/`)}>
              <FigureGlyph dots={f.data.dots} name={f.data.name} size={3.5} />
              <span class="figure-name">{f.data.name}</span>
              <span class="figure-translation">{f.data.translation}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="paths">
    <div>
      <h2>The twelve houses</h2>
      <p>
        Every question belongs to one of the twelve houses of heaven: substance to the second,
        marriage to the seventh, honours to the tenth. Each house page gathers what the sources say
        a figure signifies when it falls there.
      </p>
      <p><a href={withBase('/houses/')}>The houses and their significations →</a></p>
    </div>
    <div>
      <h2>The reading techniques</h2>
      <p>
        Witnesses and Judge, the springing of figures, aspects and dignities, the projection of
        points: the methods by which the old geomancers turned a chart into an answer.
      </p>
      <p><a href={withBase('/techniques/')}>The techniques →</a></p>
    </div>
  </section>

  <section>
    <h2>The library</h2>
    <p>The historical texts, reproduced in full where they are short enough, and in faithful extracts where they are not:</p>
    <ul>
      {
        sources.map((s) => (
          <li>
            <a href={withBase(`/library/${s.id}/`)}>
              {s.data.author}, <em>{s.data.title}</em> ({s.data.year})
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>

<style>
  .hero {
    max-width: var(--measure);
    margin: 0 auto;
  }
  .hero h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }
  .hero p {
    font-size: var(--text-md);
  }
  .start {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: var(--space-6) 0;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }
  .start a {
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    background: var(--color-bg-raised);
  }
  .start a:hover {
    border-color: var(--color-rubric);
  }
  section {
    max-width: var(--measure);
    margin: var(--space-12) auto 0;
  }
  .figure-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
    gap: var(--space-4);
  }
  .figure-grid a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    background: var(--color-bg-raised);
    color: var(--color-ink);
  }
  .figure-grid a:hover {
    border-color: var(--color-rubric);
    color: var(--color-rubric);
  }
  .figure-name {
    font-weight: 600;
    font-variant: small-caps;
    letter-spacing: 0.03em;
  }
  .figure-translation {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .course-card {
    border: 1px solid var(--color-border-strong);
    border-left: 3px solid var(--color-rubric);
    border-radius: var(--radius);
    background: var(--color-bg-raised);
    padding: var(--space-6);
  }
  .course-card h2 {
    margin-top: 0;
  }
  .paths {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-8);
  }
  .paths h2 {
    margin-top: 0;
  }
</style>
