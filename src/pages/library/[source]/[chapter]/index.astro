---
import { withBase } from '../../../../lib/url';
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../../../layouts/Base.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import { chaptersOf, chapterSlug } from '../../../../lib/library';

export async function getStaticPaths() {
  const chapters = await getCollection('library');
  return chapters.map((chapter) => ({
    params: { source: chapter.data.source.id, chapter: chapterSlug(chapter) },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;
const source = await getEntry('sources', chapter.data.source.id);
if (!source) throw new Error(`missing source for ${chapter.id}`);

const siblings = await chaptersOf(source.id);
const idx = siblings.findIndex((c) => c.id === chapter.id);
const prev = siblings[idx - 1];
const next = siblings[idx + 1];

const { Content } = await render(chapter);

const jsonLd = [
  {
    '@type': 'Article',
    headline: chapter.data.title,
    isPartOf: {
      '@type': 'Book',
      name: source.data.title,
      author: { '@type': 'Person', name: source.data.author },
      datePublished: String(source.data.year),
      ...(source.data.archiveUrl ? { isBasedOn: source.data.archiveUrl } : {}),
    },
  },
];
---

<Base title={chapter.data.title} description={chapter.data.description} type="article" jsonLd={jsonLd}>
  <Breadcrumbs
    items={[
      { name: 'Library', href: '/library/' },
      { name: source.data.shortTitle, href: `/library/${source.id}/` },
      { name: chapter.data.title },
    ]}
  />
  <article class="library-text">
    <p class="kicker">{source.data.title} ({source.data.year})</p>
    <h1>{chapter.data.title}</h1>
    {chapter.data.locator && <p class="chapter-locator">{chapter.data.locator}</p>}
    <Content />
  </article>
  <nav class="chapter-nav" aria-label="Chapters">
    {prev && <a href={withBase(`/library/${source.id}/${chapterSlug(prev)}/`)}>← {prev.data.title}</a>}
    {next && <a href={withBase(`/library/${source.id}/${chapterSlug(next)}/`)}>{next.data.title} →</a>}
  </nav>
</Base>

<style>
  .kicker {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-rubric);
    margin-bottom: var(--space-1);
  }
  .library-text :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
  }
  .chapter-locator {
    margin: calc(var(--space-1) * -1) 0 var(--space-8);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .library-text :global(.source-locator) {
    display: inline-block;
    margin: 0 0.1rem;
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-raised);
    color: var(--color-ink-faint);
    font-family: var(--font-ui);
    font-size: 0.72em;
    line-height: 1.45;
    vertical-align: 0.08em;
  }
  .library-text :global(.source-locator--block),
  .library-text :global(div.source-locator) {
    display: block;
    width: fit-content;
    margin: var(--space-7) auto var(--space-3);
    padding: 0.08rem 0.5rem;
  }
  .library-text :global(.source-margin) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    max-width: 100%;
    margin: 0 0.25rem 0.15rem 0;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-inset);
    color: var(--color-ink-muted);
    font-family: var(--font-ui);
    font-size: 0.72em;
    line-height: 1.5;
    vertical-align: middle;
  }
  .library-text :global(.source-margin__label),
  .library-text :global(.library-note__label),
  .library-text :global(.witness-band__label) {
    color: var(--color-rubric);
    font-variant: small-caps;
    letter-spacing: 0.06em;
    text-transform: lowercase;
  }
  .library-text :global(.library-note) {
    margin: var(--space-6) 0;
    padding: var(--space-3) var(--space-4);
    border-left: 2px solid var(--color-border-strong);
    background: color-mix(in srgb, var(--color-bg-raised) 70%, transparent);
    color: var(--color-ink-muted);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    line-height: 1.55;
  }
  .library-text :global(.library-note__label) {
    display: block;
    margin-bottom: var(--space-1);
  }
  .library-text :global(.library-glyph) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0 0.1rem;
    color: var(--color-ink);
    vertical-align: middle;
    white-space: nowrap;
  }
  .library-text :global(.library-glyph__dots) {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.08rem;
    min-width: 0.95rem;
  }
  .library-text :global(.library-glyph__line) {
    display: flex;
    justify-content: center;
    gap: 0.16rem;
    height: 0.18rem;
    min-width: 0.7rem;
  }
  .library-text :global(.library-glyph__line i) {
    display: block;
    width: 0.18rem;
    height: 0.18rem;
    border-radius: 999px;
    background: currentColor;
  }
  .library-text :global(.library-glyph__name) {
    font-family: var(--font-ui);
    font-size: 0.72em;
    color: var(--color-ink-muted);
  }
  .library-text :global(.geo-figure) {
    font-size: 0.75em;
  }
  .library-text :global(.source-row) {
    display: grid;
    gap: 0;
    margin: var(--space-3) 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg-raised);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }
  .library-text :global(.source-row--2) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .library-text :global(.source-row--3) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .library-text :global(.source-row--4) {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .library-text :global(.source-row__cell) {
    min-width: 0;
    padding: var(--space-3);
    border-left: 1px solid var(--color-border);
  }
  .library-text :global(.source-row__cell:first-child) {
    border-left: 0;
  }
  .library-text :global(.witness-band) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-2);
    margin: var(--space-3) 0 var(--space-4);
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    background: var(--color-bg-raised);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }
  .library-text :global(.witness-band > span) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .library-text :global(.source-diagram) {
    margin: var(--space-8) auto;
    text-align: center;
  }
  .library-text :global(.source-diagram img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    border: 1px solid var(--color-border-strong);
    background: white;
  }
  .library-text :global(.source-diagram figcaption) {
    max-width: 42rem;
    margin: var(--space-2) auto 0;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  @media (max-width: 760px) {
    .library-text :global(.source-row),
    .library-text :global(.source-row--2),
    .library-text :global(.source-row--3),
    .library-text :global(.source-row--4),
    .library-text :global(.witness-band) {
      display: block;
      overflow-x: auto;
    }
    .library-text :global(.source-row__cell) {
      border-left: 0;
      border-top: 1px solid var(--color-border);
    }
    .library-text :global(.source-row__cell:first-child) {
      border-top: 0;
    }
    .library-text :global(.witness-band > span + span) {
      margin-top: var(--space-2);
      padding-top: var(--space-2);
      border-top: 1px solid var(--color-border);
    }
  }
  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-12);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }
</style>
